vars /game_vars
    CCC/levels level_ptr
    // x * 16, y * 16
    U puffle_x = 224
    U puffle_y = 160
    U movement_timer = 0
    U movement_direction = 0
    U[240] current_level
    TileDelta tile_delta = TileDelta(0, 0, 0)
    U level_number = 1
    Coord spawn_point = Coord(16, 16)
    Bool has_key = false
    Coord update_key_tile = Coord(0, 0)

ct U TILE_LENGTH = 16
ct U MOVEMENT_LENGTH = 8
ct U MOVEMENT_CONSTANT = TILE_LENGTH / MOVEMENT_LENGTH

ct U DIRECTION_UP = 1
ct U DIRECTION_DOWN = 2
ct U DIRECTION_LEFT = 3
ct U DIRECTION_RIGHT = 4

struct TileDelta
    U type
    U x
    U y

// a = ice
// b = wall
// c = water
// d = goal
// e = background
// f = thick ice
// k = key tile
// l = lock tile
charmap("AECBDFKL", 0)


